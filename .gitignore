# 依赖目录 - 存放项目依赖，不需要提交到 Git
node_modules/
.pnp/
.pnp.js

# 构建输出 - RsPress 构建生成的临时文件
.rsbuild/
.rspress/
dist/
build/
doc_build/
*.log

# IDE 相关文件 - 各编辑器生成的配置文件
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# 环境变量 - 存放敏感信息（API Key、密码等）
.env
.env.local
.env.*.local

# SQLite 数据库文件 - 轻量级数据库文件
*.db
*.sqlite
*.sqlite3
